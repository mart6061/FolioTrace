{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "FoleoTrader/Dockerfile",
    "watchPatterns": [
      "FoleoTrader/**",
      "FolioTrace.slnx",
      ".dockerignore"
    ]
  },
  "deploy": {
    "startCommand": "dotnet FoleoTrader.dll --urls http://0.0.0.0:${PORT:-8080}",
    "healthcheckPath": "/",
    "healthcheckTimeout": 300,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
