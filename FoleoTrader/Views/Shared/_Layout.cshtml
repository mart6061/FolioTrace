<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta http-equiv="refresh" content="5" />
    <title>@(ViewData["Title"] ?? "FoleoTrader") - FoleoTrader</title>
    <style>
        :root {
            color-scheme: light;
            font-family: Inter, Segoe UI, Arial, sans-serif;
            background: #f6f8fb;
            color: #172033;
        }

        body {
            margin: 0;
        }

        header {
            background: #172033;
            color: white;
            padding: 14px 24px;
        }

        .header-inner {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 18px;
            max-width: 1600px;
            margin: 0 auto;
        }

        main {
            padding: 20px 24px 36px;
        }

        h1 {
            font-size: 22px;
            margin: 0;
        }

        nav {
            display: flex;
            gap: 6px;
        }

        nav a {
            border: 1px solid rgb(255 255 255 / 0.2);
            border-radius: 6px;
            color: #dbe5f2;
            font-size: 14px;
            font-weight: 700;
            padding: 7px 13px;
            text-decoration: none;
        }

        nav a:hover,
        nav a:focus-visible,
        nav a.active {
            border-color: #8fd6b2;
            background: #176b4b;
            color: white;
            outline: none;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            background: white;
            border: 1px solid #d8dee8;
        }

        th, td {
            border-bottom: 1px solid #e5e9f0;
            padding: 9px 10px;
            text-align: left;
            vertical-align: top;
            font-size: 13px;
        }

        th {
            background: #eef2f7;
            color: #334155;
            font-weight: 700;
        }

        code {
            font-family: Consolas, monospace;
            font-size: 12px;
            overflow-wrap: anywhere;
        }

        details {
            max-width: 720px;
        }

        summary {
            cursor: pointer;
            font-weight: 700;
        }

        .muted {
            color: #667085;
        }

        .status {
            display: inline-flex;
            border-radius: 999px;
            background: #e8f5ee;
            color: #176b4b;
            font-size: 12px;
            font-weight: 700;
            padding: 3px 8px;
        }

        .status.complete {
            background: #e8eef7;
            color: #334155;
        }

        @@media (max-width: 640px) {
            .header-inner {
                align-items: flex-start;
                flex-direction: column;
            }
        }
    </style>
</head>
<body>
    <header>
        <div class="header-inner">
            <h1>FoleoTrader</h1>
            <nav aria-label="FoleoTrader sections">
                <a asp-controller="FoleoTrader" asp-action="Index" class="@(ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : null)">FIX</a>
                <a asp-controller="FoleoTrader" asp-action="FTP" class="@(ViewContext.RouteData.Values["action"]?.ToString() == "FTP" ? "active" : null)">FTP</a>
            </nav>
        </div>
    </header>
    <main>
        @RenderBody()
    </main>
</body>
</html>
