    "@tailwindcss/vite": "^4.1.0",
    "@types/node": "^25.8.0",
    "svelte": "^5.34.0",
    "svelte-check": "^4.2.0",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.8.0",
    "vite": "^6.3.0"
  },
  "dependencies": {},
  "engines": {
  "node": ">=22.0.0"
  }
