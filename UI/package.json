{
  "name": "foliotrace-ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",

  
"scripts": {
  "ensure-dev-cert": "node scripts/ensure-dev-cert.mjs",
  "dev": "node scripts/run-vite.mjs dev --host localhost --port 5173",
  "build": "vite build",
  "preview": "node scripts/run-vite.mjs preview --host localhost --port 4173",
  "start": "node build/index.js",
  "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json"
},

  "devDependencies": {
    "@sveltejs/adapter-node": "^5.3.1",
    "@sveltejs/kit": "^2.22.0",
    "@sveltejs/vite-plugin-svelte": "^5.1.0",
    "@tailwindcss/vite": "^4.1.0",
    "@types/node": "^25.8.0",
    "svelte": "^5.34.0",
    "svelte-check": "^4.2.0",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.8.0",
    "vite": "^6.3.0"
  }
}
