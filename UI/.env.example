API_BASE_URL=https://localhost:7058/API

# WorkOS AuthKit. Copy this file to .env and set all values before running authenticated UI routes.
WORKOS_CLIENT_ID=client_replace_with_your_workos_client_id
WORKOS_API_KEY=sk_test_replace_with_your_workos_api_key
WORKOS_REDIRECT_URI=https://localhost:5173/callback
WORKOS_COOKIE_PASSWORD=replace-with-at-least-32-characters
