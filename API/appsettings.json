{
  "ConnectionStrings": {
    "FolioTrace": ""
  },
  "AggregateMaintenance": {
    "Enabled": true,
    "PeriodicDelay": "00:10:00",
    "EventTriggerCount": 100,
    "EventTriggerDelay": "00:00:30",
    "DateWindows": {
      "DaysFromToday": 0,
      "EndOfWeeksFromToday": 0,
      "EndOfMonthsFromToday": 0
    }
  },

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Observability": {
    "ServiceName": "FolioTrace.API",
    "OpenTelemetryEnabled": true,
    "OtlpExporterEnabled": false,
    "OtlpEndpoint": "",
    "OtlpProtocol": "Grpc"
  },
  "RequestTrace": {
    "Enabled": true,
    "CaptureApi": true,
    "CaptureUi": true,
    "CaptureBodies": true,
    "Capture500StackTraces": true,
    "CaptureLogMessages": false,
    "MinimumLogLevel": "Warning",
    "MaximumBodyCharacters": 32000,
    "CapturedContentTypePrefixes": [
      "application/json",
      "application/problem+json",
      "text/"
    ],
    "ExcludedPathPrefixes": [
      "/Diagnostics/RequestTrace/Events",
      "/openapi",
      "/swagger"
    ],
    "RedactedHeaders": [
      "Authorization",
      "Cookie",
      "Set-Cookie",
      "X-Api-Key"
    ]
  },
  "AllowedHosts": "*"
}

